{
  "design_system": "Vibe Coding",
  "category": "Semantic Status Colors — OP Video Engine",
  "version": "1.1.0",
  "description": "Mapeo de colores semánticos de estado para OP Video Engine. Se usan en StatusBadge, indicadores de progreso de render, flujo de QC y aprobacion del cliente. Complementa colors_system.json con tokens específicos del dominio.",
  "status_colors": {
    "approved": {
      "background": "rgba(34, 197, 94, 0.15)",
      "text": "#22C55E",
      "border": "rgba(34, 197, 94, 0.3)",
      "icon": "#22C55E",
      "usage": "QC aprobado, checks que pasan, validación exitosa"
    },
    "client_approved": {
      "background": "rgba(21, 128, 61, 0.15)",
      "text": "#15803D",
      "border": "rgba(21, 128, 61, 0.3)",
      "icon": "#15803D",
      "usage": "Cliente aprobó — variante más oscura de approved para diferenciarlo"
    },
    "rejected": {
      "background": "rgba(239, 68, 68, 0.15)",
      "text": "#EF4444",
      "border": "rgba(239, 68, 68, 0.3)",
      "icon": "#EF4444",
      "usage": "QC rechazó, checks críticos que fallan, errores bloqueantes"
    },
    "warning": {
      "background": "rgba(245, 158, 11, 0.15)",
      "text": "#F59E0B",
      "border": "rgba(245, 158, 11, 0.3)",
      "icon": "#F59E0B",
      "usage": "Needs fix, checks importantes que fallan, advertencias no bloqueantes"
    },
    "pending": {
      "background": "rgba(107, 114, 128, 0.15)",
      "text": "#9CA3AF",
      "border": "rgba(107, 114, 128, 0.3)",
      "icon": "#9CA3AF",
      "usage": "QC pendiente, uploaded, estados de espera"
    },
    "in_review": {
      "background": "rgba(139, 92, 246, 0.15)",
      "text": "#8B5CF6",
      "border": "rgba(139, 92, 246, 0.3)",
      "icon": "#8B5CF6",
      "usage": "Client review, en proceso de revisión"
    },
    "delivered": {
      "background": "rgba(67, 97, 239, 0.15)",
      "text": "#4361EF",
      "border": "rgba(67, 97, 239, 0.3)",
      "icon": "#4361EF",
      "usage": "Entregado. Usa el op_blue_600 principal del sistema"
    }
  },
  "validation_check_colors": {
    "critical": {
      "background": "rgba(239, 68, 68, 0.10)",
      "text": "#EF4444",
      "icon": "#EF4444",
      "description": "Checks críticos (bloquean avance)"
    },
    "important": {
      "background": "rgba(245, 158, 11, 0.10)",
      "text": "#F59E0B",
      "icon": "#F59E0B",
      "description": "Checks importantes (advertencia, no bloquean)"
    },
    "info": {
      "background": "rgba(34, 197, 94, 0.10)",
      "text": "#22C55E",
      "icon": "#22C55E",
      "description": "Checks informativos (cumple correctamente)"
    }
  },
  "job_status_to_color_map": {
    "uploaded": "pending",
    "queued": "pending",
    "rendering": "in_review",
    "error": "rejected",
    "needs_fix": "warning",
    "qc_pending": "pending",
    "qc_approved": "approved",
    "qc_rejected": "rejected",
    "client_review": "in_review",
    "client_approved": "client_approved",
    "delivered": "delivered"
  }
}
